#!/bin/bash
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_DIR="{{ backup_path }}/${TIMESTAMP}"
mkdir -p ${BACKUP_DIR}

# Stop ZooKeeper to ensure consistency
systemctl stop zookeeper

{% if backup_type == 'full' %}
cp -r {{ zookeeper_data_dir }} ${BACKUP_DIR}/data
cp -r {{ zookeeper_datalog_dir }} ${BACKUP_DIR}/log
{% elif backup_type == 'incremental' %}
LAST_BACKUP=$(ls -t {{ backup_path }}/*.tar.gz 2>/dev/null | head -1)
if [ -z "${LAST_BACKUP}" ]; then
    cp -r {{ zookeeper_data_dir }} ${BACKUP_DIR}/data
    cp -r {{ zookeeper_datalog_dir }} ${BACKUP_DIR}/log
else
    mkdir -p ${BACKUP_DIR}/log
    find {{ zookeeper_datalog_dir }} -newer ${LAST_BACKUP} -type f \
        -exec cp {} ${BACKUP_DIR}/log/ \;
fi
{% endif %}

# Start ZooKeeper after backup
systemctl start zookeeper

# Compress backup
tar -czf {{ backup_path }}/zookeeper_{{ backup_type }}_${TIMESTAMP}.tar.gz \
    -C {{ backup_path }} ${TIMESTAMP}

# Cleanup temp dir
rm -rf ${BACKUP_DIR}

# Fix permission
chown zookeeper:zookeeper {{ backup_path }}/zookeeper_{{ backup_type }}_${TIMESTAMP}.tar.gz

# Remove old backups
find {{ backup_path }} -name "*.tar.gz" -mtime +{{ backup_retention_days }} -delete